html(lang=lang)
  head
    meta(charset="UTF-8")
    meta(name="author" content="dough10")
    meta(name="csrf-token" content=csrf)
    meta(name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover")
    link(nonce=nonce rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css")
    style(nonce=nonce).
      body {
        padding: 16px;
      }
      form {
        max-width: 500px;
      }
  body
    h1 Welcome #{user.firstName} #{user.lastName}

    a(href="/") back

    form(method="POST")
      div
        label(for="id") ID
        input#id(type="text" name="id")
      
      div
        label(for="title") Title
        input#title(type="text" name="title")

      div
        label Paragraphs

        #paragraph-container
          input(type="text" name="paragraphs[]" placeholder="Paragraph 1")

        button#add-paragraph(type="button") Add Paragraph

      br
      button(type="submit") Submit

    h4 Active Alerts
    ul
      each alert in alerts
        li(data-version=alert.version data-id=alert.id) #{alert.id}: #{alert.title}
      else
        li No active alerts

  script(nonce=nonce).
    let count = 1;

    function opt(body = null) {
      const options = {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
        }
      };

      if (body && body instanceof HTMLFormElement) {
        options.body = new FormData(body);
      } else if (body && typeof body === 'object') {
        options.headers['Content-Type'] = 'application/json';
        options.body = JSON.stringify(body);
      }

      return options;
    };

    window.addEventListener('DOMContentLoaded', () => {

      const form = document.querySelector('form');
      const addP = document.getElementById('add-paragraph');
      const container = document.getElementById('paragraph-container');

      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();

        const res = await fetch('/addAlert', opt({
          id: form.id.value,
          title: form.title.value,
          paragraphs: [...document.querySelectorAll('[name="paragraphs[]"]')]
            .map(input => input.value)
        }));

        if (!res.ok) console.error('Submit Failed');
      });

      addP.addEventListener('click', () => {
        count++;

        const input = document.createElement('input');
        input.type = 'text';
        input.name = 'paragraphs[]';
        input.placeholder = 'Paragraph ' + count;

        container.append(document.createElement('br'), input);
      });

      const activeAlerts = [...document.querySelectorAll('ul>li')];
      activeAlerts.forEach(alert => {
        alert.addEventListener('click', _ => {
          const {version, id} = alert.data;
          console.log(version, id);
        });
      });
    }); 