html(lang=lang)
  head
    meta(charset="UTF-8")
    meta(name="author" content="dough10")
    meta(name="csrf-token" content=csrf)
    meta(name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover")
    link(nonce=nonce rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css")
    script(nonce=nonce, type="text/javascript") window.user = !{JSON.stringify(user)};
    style(nonce=nonce).
      body {
        padding: 16px;
      }
      form {
        max-width: 500px;
      }
  body
    h1 Welcome #{user.firstName} #{user.lastName}

    form(method="POST")
      div
        label(for="id") ID
        input#id(type="text" name="id")
      
      div
        label(for="title") Title
        input#title(type="text" name="title")

      div
        label Paragraphs

        #paragraph-container
          input(type="text" name="paragraphs[]")

        button#add-paragraph(type="button") Add Paragraph

      br
      button(type="submit") Submit

    button(type="button" id="del" disabled) delete

    h4 Active Alerts
    ul
      each alert in alerts
        li(
          data-version=alert.version 
          data-id=alert.id
          data-title=alert.title
          data-p=JSON.stringify(alert.paragraphs)
        ) #{alert.id}: #{alert.title}
      else
        li No active alerts

  script(nonce=nonce, src="submit.min.js")