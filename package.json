{
  "name": "customradio",
  "version": "1.13.3",
  "description": "build custion radio.txt for use on hiby audio players",
  "main": "index.js",
  "scripts": {
    "start:prod": "node --expose-gc dist/index.js",
    "prebuild": "bash build_assets/pre.sh",
    "build": "npx webpack --config config/runtime.config.js && npx webpack --config config/webpack.config.js",
    "postbuild": "bash build_assets/post.sh",
    "test": "web-test-runner \"html/js/CustomRadioApp/**/*.test.js\" --node-resolve && mocha",
    "version++": "node build_assets/incriment-version.js && node assets/make-docs.js",
    "build-docker": "bash build_assets/build-container.sh \"registry.dough10.me/customradio\"",
    "docs": "node assets/make-docs.js",
    "run container": "bash build_assets/run.sh",
    "translate-front": "node scripts/translate-js.js front bg cs de es fr fi it nl he hu ja kk ko pl pt ro ru sk sr sv tr uk vi zh",
    "translate-back": "node scripts/translate-js.js back bg cs de es fr fi it nl he hu ja kk ko pl pt ro ru sk sr sv tr uk vi zh"
  },
  "author": "dough10",
  "license": "ISC",
  "dependencies": {
    "@workos-inc/node": "^8.10.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "mongodb": "^7.1.1",
    "node-schedule": "^2.1.1",
    "prom-client": "^15.1.3",
    "pug": "^3.0.4",
    "redis": "^5.11.0",
    "sqlite3": "^6.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@open-wc/testing": "^4.0.0",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "@webpack-cli/generators": "^3.0.7",
    "axios-mock-adapter": "^2.1.0",
    "babel-loader": "^10.1.1",
    "chai": "^6.2.2",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "jsdoc-to-markdown": "^9.1.3",
    "jshint": "^2.13.6",
    "mini-css-extract-plugin": "^2.10.2",
    "mocha": "^11.7.5",
    "openai": "^6.33.0",
    "sinon": "^21.0.3",
    "sinon-chai": "^4.0.1",
    "terser-webpack-plugin": "^5.4.0",
    "version-incrementer": "^0.1.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
